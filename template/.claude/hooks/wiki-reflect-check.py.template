#!/usr/bin/env python3
"""Stop hook companion to wiki-auto-reflect.md (Unix / Python 3).

Reads transcript JSONL, decides whether this turn touched domain content
without filing anything to {{VAULT_DIR}}/wiki/, and if so blocks the stop
with a reminder so the assistant gets one more pass to judge & file.

Soft-rule philosophy preserved: the hook NUDGES, it does not enforce.
The assistant still applies wiki-auto-reflect.md judgment in the next pass.
Fail-open on any error — never block the stop on script bugs.
"""
import json
import os
import re
import sys

# Force UTF-8 on stdin/stdout. On Windows, Python defaults sys.stdout to the
# system codepage (cp949 / Windows-1252), which can't encode the em dash and
# CJK characters in our reason text or in transcript JSON.
try:
    sys.stdin.reconfigure(encoding="utf-8")
    sys.stdout.reconfigure(encoding="utf-8")
except Exception:
    pass


def main() -> int:
    try:
        raw = sys.stdin.read()
        if not raw:
            return 0
        hook = json.loads(raw)
    except Exception:
        return 0

    # Loop guard — already in a stop-hook-induced retry, let it through.
    if hook.get("stop_hook_active"):
        return 0

    transcript = hook.get("transcript_path")
    if not transcript or not os.path.exists(transcript):
        return 0

    try:
        with open(transcript, encoding="utf-8") as f:
            lines = [ln for ln in f.read().splitlines() if ln.strip()]
    except Exception:
        return 0
    if not lines:
        return 0

    # --- Find current turn boundary: most recent "real" user message ---
    turn_start = 0
    for i in range(len(lines) - 1, -1, -1):
        try:
            e = json.loads(lines[i])
        except Exception:
            continue
        if e.get("type") != "user":
            continue
        content = e.get("message", {}).get("content")
        is_real = False
        if isinstance(content, str) and content:
            is_real = True
        elif isinstance(content, list):
            for block in content:
                if isinstance(block, dict) and block.get("type") == "text" and block.get("text"):
                    is_real = True
                    break
        if is_real:
            turn_start = i
            break

    def path_contains(path: str, needles) -> bool:
        if not path:
            return False
        low = path.lower().replace("\\", "/")
        return any(n in low for n in needles)

    wiki_needles = ["{{VAULT_DIR}}/wiki/"]
    source_needles = ["{{VAULT_DIR}}/raw/sources/", "docs/", "design/"]

    # --- Intent detection from this turn's user message ---
    user_text = ""
    try:
        u = json.loads(lines[turn_start])
        c = u.get("message", {}).get("content")
        if isinstance(c, str):
            user_text = c
        elif isinstance(c, list):
            for b in c:
                if isinstance(b, dict) and b.get("type") == "text" and b.get("text"):
                    user_text += b["text"] + "\n"
    except Exception:
        pass

    intent_regex = r"{{INTENT_REGEX}}"
    user_intent = False
    if user_text and intent_regex:
        try:
            if re.search(intent_regex, user_text, re.IGNORECASE):
                user_intent = True
        except re.error:
            pass

    # --- Scan turn for tool uses ---
    wrote_wiki = False
    touched_source = False

    for i in range(turn_start, len(lines)):
        try:
            e = json.loads(lines[i])
        except Exception:
            continue
        if e.get("type") != "assistant":
            continue
        c = e.get("message", {}).get("content")
        if not isinstance(c, list):
            continue
        for block in c:
            if not isinstance(block, dict) or block.get("type") != "tool_use":
                continue
            tool = block.get("name")
            inp = block.get("input") or {}
            if tool in ("Edit", "Write", "NotebookEdit", "MultiEdit"):
                p = inp.get("file_path")
                if path_contains(p, wiki_needles):
                    wrote_wiki = True
                if path_contains(p, source_needles):
                    touched_source = True
            elif tool == "Read":
                p = inp.get("file_path")
                if path_contains(p, source_needles):
                    touched_source = True

    if wrote_wiki:
        return 0
    if not (touched_source or user_intent):
        return 0

    reason = (
        "[create-llm-wiki hook] This turn touched domain content (source doc "
        "read/edit, or intent keyword in the user prompt). Per "
        ".claude/rules/wiki-auto-reflect.md, judge whether new domain knowledge "
        "was produced. If yes, file it now (1-3 pages under {{VAULT_DIR}}/wiki/"
        "{sources,entities,concepts,synthesis}/), update {{VAULT_DIR}}/wiki/"
        "index.md, and append {{VAULT_DIR}}/wiki/log.md. If the work was "
        "actually pure code/build/tooling, or the wiki already covers it, say "
        "so in one sentence and stop. One pass only — do not loop."
    )

    out = {"decision": "block", "reason": reason}
    sys.stdout.write(json.dumps(out, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception:
        sys.exit(0)
